<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

  <?define ProductName = "LiveLingo" ?>
  <?define Manufacturer = "LiveLingo" ?>
  <?define UpgradeCode = "6A3F8E2B-1C4D-4F5A-9B7E-D8E2F1A3C5B9" ?>

  <Package Id="$(ProductName).Desktop"
           Name="$(ProductName)"
           Manufacturer="$(Manufacturer)"
           Version="$(Version)"
           UpgradeCode="$(UpgradeCode)"
           Scope="perMachine">

    <MajorUpgrade DowngradeErrorMessage="A newer version of $(ProductName) is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <StandardDirectory Id="ProgramFiles6432Folder">
      <Directory Id="INSTALLFOLDER" Name="$(ProductName)">
        <Files Include="$(PublishDir)\**" />
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ProgramMenuDir" Name="$(ProductName)">
        <Component Id="StartMenuShortcutComponent" Guid="*">
          <Shortcut Id="StartMenuShortcut"
                    Name="$(ProductName)"
                    Target="[INSTALLFOLDER]LiveLingo.Desktop.exe"
                    WorkingDirectory="INSTALLFOLDER" />
          <RemoveFolder Id="RemoveProgramMenuDir" On="uninstall" />
          <RegistryValue Root="HKCU"
                         Key="Software\$(Manufacturer)\$(ProductName)"
                         Name="StartMenuShortcut"
                         Type="integer"
                         Value="1"
                         KeyPath="yes" />
        </Component>
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="DesktopFolder">
      <Component Id="DesktopShortcutComponent" Guid="*">
        <Shortcut Id="DesktopShortcut"
                  Name="$(ProductName)"
                  Target="[INSTALLFOLDER]LiveLingo.Desktop.exe"
                  WorkingDirectory="INSTALLFOLDER" />
        <RegistryValue Root="HKCU"
                       Key="Software\$(Manufacturer)\$(ProductName)"
                       Name="DesktopShortcut"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />
      </Component>
    </StandardDirectory>

  </Package>

</Wix>
