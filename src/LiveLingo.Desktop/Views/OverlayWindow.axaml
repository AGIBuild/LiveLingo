<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:LiveLingo.Desktop.ViewModels"
        x:Class="LiveLingo.Desktop.Views.OverlayWindow"
        x:DataType="vm:OverlayViewModel"
        SystemDecorations="None"
        Topmost="True"
        CanResize="False"
        ShowInTaskbar="False"
        Background="Transparent"
        TransparencyLevelHint="AcrylicBlur"
        Width="600" SizeToContent="Height" MaxHeight="500"
        WindowStartupLocation="Manual">

    <Window.Styles>
        <Style Selector="TextBox.source">
            <Setter Property="Background" Value="{StaticResource BgDeepBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource FgPrimaryBrush}"/>
            <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Watermark" Value=""/>
        </Style>
        <Style Selector="SelectableTextBlock.translation">
            <Setter Property="Foreground" Value="{StaticResource FgSecondaryBrush}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Padding" Value="12,6"/>
        </Style>
        <Style Selector="TextBlock.status">
            <Setter Property="Foreground" Value="{StaticResource FgTertiaryBrush}"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
        <Style Selector="Button.modeToggle">
            <Setter Property="Background" Value="{StaticResource BgElevatedBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource FgSecondaryBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="MinHeight" Value="0"/>
        </Style>
        <Style Selector="Border.kbd">
            <Setter Property="Background" Value="{StaticResource BgElevatedBrush}"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Padding" Value="4,1"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style Selector="Border.kbd TextBlock">
            <Setter Property="Foreground" Value="{StaticResource FgMutedBrush}"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontFamily" Value="Consolas, Menlo, monospace"/>
        </Style>
        <Style Selector="Button.iconBtn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource FgMutedBrush}"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="Popup Button:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource BgElevatedBrush}"/>
            <Setter Property="CornerRadius" Value="4"/>
        </Style>
        <Style Selector="Button.copyBtn">
            <Setter Property="Background" Value="{StaticResource BgElevatedBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource FgMutedBrush}"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
    </Window.Styles>

    <Panel Name="RootPanel" Opacity="0">
        <Panel.Transitions>
            <Transitions>
                <DoubleTransition Property="Opacity" Duration="0:0:0.15"/>
            </Transitions>
        </Panel.Transitions>

        <ExperimentalAcrylicBorder Name="AcrylicBg" CornerRadius="12" IsHitTestVisible="False">
            <ExperimentalAcrylicBorder.Material>
                <ExperimentalAcrylicMaterial
                    BackgroundSource="Digger"
                    TintColor="{StaticResource BgDeep}"
                    TintOpacity="0.92"
                    MaterialOpacity="0.92"/>
            </ExperimentalAcrylicBorder.Material>
        </ExperimentalAcrylicBorder>

        <Border CornerRadius="12" IsHitTestVisible="False"
                BorderBrush="#10FFFFFF" BorderThickness="1"/>

        <Border CornerRadius="12" Padding="0">
            <Grid RowDefinitions="Auto,Auto,Auto,*,Auto">

                <!-- Title bar -->
                <Border Grid.Row="0" Name="DragHandle"
                        Background="Transparent" Cursor="Hand"
                        Height="28" CornerRadius="12,12,0,0">
                    <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                        <TextBlock Grid.Column="1" Text="LiveLingo"
                                   FontSize="11" Foreground="{StaticResource FgMutedBrush}"
                                   Margin="0,0,4,0" VerticalAlignment="Center"/>
                        <Button Grid.Column="2" Classes="iconBtn"
                                Content="⚙" FontSize="13"
                                Command="{Binding OpenSettingsCommand}"
                                ToolTip.Tip="Settings"
                                Margin="0,0,2,0" VerticalAlignment="Center"/>
                        <Button Grid.Column="3" Content="✕"
                                Click="CloseButton_Click"
                                FontSize="12" Foreground="{StaticResource FgSecondaryBrush}"
                                Background="Transparent" BorderThickness="0"
                                Padding="6,2" Margin="0,0,8,0"
                                VerticalAlignment="Center" Cursor="Hand"
                                MinWidth="0" MinHeight="0"/>
                    </Grid>
                </Border>

                <!-- Source input -->
                <Grid Grid.Row="1" Margin="14,0,14,0">
                    <TextBox Classes="source"
                             Text="{Binding SourceText, Mode=TwoWay}"
                             Watermark="{Binding SourceHint}"
                             Name="SourceInput"
                             MinHeight="60" MaxHeight="120"/>
                    <TextBlock Text="{Binding SourceTextLength}"
                               FontSize="10" Foreground="#48FFFFFF"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Bottom"
                               Margin="0,0,10,6"
                               IsHitTestVisible="False"/>
                </Grid>

                <!-- Loading indicator -->
                <ProgressBar Grid.Row="2" IsIndeterminate="True"
                             IsVisible="{Binding IsTranslating}"
                             Height="2" Margin="14,4,14,0"
                             Foreground="{StaticResource AccentBrush}"
                             Background="{StaticResource BgSurfaceBrush}"/>

                <!-- Translation result -->
                <Border Grid.Row="3" Margin="14,8,14,0"
                        CornerRadius="8" Background="{StaticResource BgSurfaceBrush}"
                        MinHeight="40"
                        IsVisible="{Binding TranslatedText,
                                    Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                    <Grid ColumnDefinitions="*,Auto">
                        <ScrollViewer Grid.Column="0"
                                      HorizontalScrollBarVisibility="Disabled"
                                      VerticalScrollBarVisibility="Auto">
                            <SelectableTextBlock Classes="translation"
                                                 Text="{Binding TranslatedText}"/>
                        </ScrollViewer>
                        <StackPanel Grid.Column="1" VerticalAlignment="Top" Margin="0,4,4,0">
                            <Button Classes="copyBtn"
                                    Command="{Binding CopyTranslationCommand}">
                                <Panel>
                                    <TextBlock Text="{Binding CopyLabel}"
                                               IsVisible="{Binding !ShowCopiedFeedback}"/>
                                    <TextBlock Text="{Binding CopiedLabel}"
                                               Foreground="{StaticResource SuccessBrush}"
                                               IsVisible="{Binding ShowCopiedFeedback}"/>
                                </Panel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Bottom bar -->
                <Grid Grid.Row="4" Margin="14,8,14,12"
                      ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto">
                    <TextBlock Grid.Column="0" Classes="status"
                               Text="{Binding StatusText}" VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                Spacing="6" HorizontalAlignment="Right"
                                VerticalAlignment="Center" Margin="8,0">
                        <Border Classes="kbd"><TextBlock Text="Ctrl+Enter"/></Border>
                        <Border Classes="kbd"><TextBlock Text="Esc"/></Border>
                    </StackPanel>

                    <Button Grid.Column="2" Classes="iconBtn"
                            Content="⇄" FontSize="16"
                            Command="{Binding SwapLanguagesCommand}"
                            ToolTip.Tip="Swap source ↔ target language"
                            Margin="0,0,4,0"/>

                    <Button Grid.Column="3" Classes="modeToggle"
                            Content="{Binding ModeLabel}"
                            Command="{Binding ToggleModeCommand}"
                            ToolTip.Tip="Toggle: Paste Only / Paste &amp; Send"
                            Margin="0,0,4,0"/>

                    <Panel Grid.Column="4" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="2">
                            <TextBlock Text="→" Foreground="{StaticResource FgMutedBrush}"
                                       FontSize="12" VerticalAlignment="Center"/>
                            <TextBlock Name="TargetLangLink"
                                       Text="{Binding SelectedTargetLanguage.Code, FallbackValue='--'}"
                                       Foreground="{StaticResource AccentBrush}" FontSize="12"
                                       Cursor="Hand" VerticalAlignment="Center"
                                       TextDecorations="Underline"
                                       ToolTip.Tip="Target language"/>
                        </StackPanel>

                        <Popup Name="LangPopup"
                               IsOpen="{Binding IsLanguagePickerOpen, Mode=TwoWay}"
                               PlacementTarget="{Binding #TargetLangLink}"
                               Placement="Top"
                               IsLightDismissEnabled="True"
                               MaxHeight="260">
                            <Border Background="{StaticResource BgSurfaceBrush}" CornerRadius="8"
                                    BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                                    Padding="4" MinWidth="140">
                                <ScrollViewer MaxHeight="240"
                                              HorizontalScrollBarVisibility="Disabled">
                                    <ItemsControl ItemsSource="{Binding AvailableTargetLanguages}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Background="Transparent"
                                                        BorderThickness="0"
                                                        HorizontalContentAlignment="Stretch"
                                                        HorizontalAlignment="Stretch"
                                                        Padding="8,6" Cursor="Hand"
                                                        Command="{Binding $parent[Window].((vm:OverlayViewModel)DataContext).SelectLanguageCommand}"
                                                        CommandParameter="{Binding}">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <TextBlock Text="{Binding Code}"
                                                                   Foreground="{StaticResource FgPrimaryBrush}"
                                                                   FontSize="12" FontWeight="SemiBold"
                                                                   Width="28"/>
                                                        <TextBlock Text="{Binding DisplayName}"
                                                                   Foreground="{StaticResource FgMutedBrush}"
                                                                   FontSize="12"/>
                                                    </StackPanel>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Panel>

                    <TextBlock Grid.Column="5"
                               Text="{Binding SelectedSourceLanguage.Code, FallbackValue='auto'}"
                               Foreground="#636366" FontSize="10"
                               VerticalAlignment="Center" Margin="6,0,0,0"
                               ToolTip.Tip="Source language (auto-detected or configured)"/>
                </Grid>
            </Grid>
        </Border>
    </Panel>
</Window>
