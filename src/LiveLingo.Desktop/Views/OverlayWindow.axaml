<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:LiveLingo.Desktop.ViewModels"
        x:Class="LiveLingo.Desktop.Views.OverlayWindow"
        x:DataType="vm:OverlayViewModel"
        SystemDecorations="None"
        Topmost="True"
        CanResize="True"
        ShowInTaskbar="False"
        Background="Transparent"
        TransparencyLevelHint="Transparent"
        Width="600" Height="300"
        MinWidth="320" MinHeight="180" MaxHeight="600"
        WindowStartupLocation="Manual">

    <Window.Resources>
        <SolidColorBrush x:Key="OvFrameBrush" Color="#D91C1C1E"/>
        <SolidColorBrush x:Key="OvPanelBrush" Color="#1C1C1E"/>
        <SolidColorBrush x:Key="OvFgPrimaryBrush" Color="#E5E5E7"/>
        <SolidColorBrush x:Key="OvFgSecondaryBrush" Color="#C7C7CC"/>
        <SolidColorBrush x:Key="OvFgTertiaryBrush" Color="#AEAEB2"/>
        <SolidColorBrush x:Key="OvFgMutedBrush" Color="#A1A1A6"/>
    </Window.Resources>

    <Window.Styles>
        <Style Selector="TextBox.source">
            <Setter Property="Background" Value="{DynamicResource OvPanelBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource OvFgPrimaryBrush}"/>
            <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Watermark" Value=""/>
        </Style>
        <Style Selector="TextBox.source:pointerover /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="{DynamicResource OvPanelBrush}"/>
        </Style>
        <Style Selector="TextBox.source:focus /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="{DynamicResource OvPanelBrush}"/>
        </Style>
        <Style Selector="SelectableTextBlock.translation">
            <Setter Property="Foreground" Value="{DynamicResource OvFgSecondaryBrush}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Padding" Value="12,6"/>
        </Style>
        <Style Selector="TextBlock.status">
            <Setter Property="Foreground" Value="{DynamicResource OvFgTertiaryBrush}"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
        <Style Selector="Button.sendBtn">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="MinHeight" Value="0"/>
        </Style>
        <Style Selector="Button.sendBtn:disabled">
            <Setter Property="Opacity" Value="0.4"/>
        </Style>
        <Style Selector="Button.iconBtn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource OvFgSecondaryBrush}"/>
            <Setter Property="FontSize" Value="15"/>
        </Style>
        <Style Selector="Popup Button:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource BgElevatedBrush}"/>
            <Setter Property="CornerRadius" Value="4"/>
        </Style>
        <Style Selector="Button.copyBtn">
            <Setter Property="Background" Value="{StaticResource BgElevatedBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource OvFgSecondaryBrush}"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Styles>

    <Panel Name="RootPanel" Opacity="0">
        <Panel.Transitions>
            <Transitions>
                <DoubleTransition Property="Opacity" Duration="0:0:0.15"/>
            </Transitions>
        </Panel.Transitions>

        <Border Name="AcrylicBg" CornerRadius="12" IsHitTestVisible="False" Background="{DynamicResource OvFrameBrush}"/>
        <Border CornerRadius="12" IsHitTestVisible="False"
                BorderBrush="#15FFFFFF" BorderThickness="1"/>

        <Border CornerRadius="12" Padding="0">
            <Grid RowDefinitions="Auto,Auto,Auto,*,Auto">

                <!-- Title bar -->
                <Border Grid.Row="0" Name="DragHandle"
                        Background="Transparent" Cursor="Hand"
                        Height="28" CornerRadius="12,12,0,0">
                    <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                        <TextBlock Grid.Column="1" Text="LiveLingo"
                                   FontSize="11" Foreground="{DynamicResource OvFgTertiaryBrush}"
                                   Margin="0,0,4,0" VerticalAlignment="Center"/>
                        <Button Grid.Column="2" Classes="iconBtn"
                                Content="⚙" FontSize="15"
                                Command="{Binding OpenSettingsCommand}"
                                ToolTip.Tip="Settings"
                                Margin="0,0,2,0" VerticalAlignment="Center"/>
                        <Button Grid.Column="3" Content="✕"
                                Click="CloseButton_Click"
                                FontSize="14" Foreground="{DynamicResource OvFgSecondaryBrush}"
                                Background="Transparent" BorderThickness="0"
                                Padding="6,2" Margin="0,0,8,0"
                                VerticalAlignment="Center" Cursor="Hand"
                                MinWidth="0" MinHeight="0"/>
                    </Grid>
                </Border>

                <!-- Source input -->
                <Grid Grid.Row="1" Margin="14,0,14,0">
                    <TextBox Classes="source"
                             Text="{Binding SourceText, Mode=TwoWay}"
                             Watermark="{Binding SourceHint}"
                             Name="SourceInput"
                             MinHeight="60" MaxHeight="120"/>
                    <TextBlock Text="{Binding SourceTextLength}"
                               FontSize="10" Foreground="{DynamicResource OvFgMutedBrush}"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Bottom"
                               Margin="0,0,10,6"
                               IsHitTestVisible="False"/>
                </Grid>

                <!-- Loading indicator -->
                <ProgressBar Grid.Row="2" IsIndeterminate="True"
                             IsVisible="{Binding IsTranslating}"
                             Height="2" Margin="14,4,14,0"
                             Foreground="{StaticResource AccentBrush}"
                             Background="{StaticResource BgSurfaceBrush}"/>

                <!-- Translation result -->
                <Border Grid.Row="3" Margin="14,8,14,0" Name="TranslationBorder"
                        CornerRadius="8" Background="{DynamicResource OvPanelBrush}"
                        MinHeight="40"
                        IsVisible="{Binding TranslatedText,
                                    Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                    <Grid ColumnDefinitions="*,Auto">
                        <ScrollViewer Grid.Column="0"
                                      HorizontalScrollBarVisibility="Disabled"
                                      VerticalScrollBarVisibility="Auto">
                            <SelectableTextBlock Classes="translation"
                                                 Text="{Binding TranslatedText}"/>
                        </ScrollViewer>
                        <StackPanel Grid.Column="1" VerticalAlignment="Top" Margin="0,4,4,0">
                            <Button Classes="copyBtn"
                                    Command="{Binding CopyTranslationCommand}">
                                <Panel>
                                    <TextBlock Text="{Binding CopyLabel}"
                                               IsVisible="{Binding !ShowCopiedFeedback}"/>
                                    <TextBlock Text="{Binding CopiedLabel}"
                                               Foreground="{StaticResource SuccessBrush}"
                                               IsVisible="{Binding ShowCopiedFeedback}"/>
                                </Panel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Bottom bar -->
                <Grid Grid.Row="4" Margin="14,8,14,12"
                      ColumnDefinitions="Auto,*,Auto,Auto">
                    <TextBlock Grid.Column="0" Classes="status"
                               Text="{Binding StatusText}" VerticalAlignment="Center"/>

                    <Panel Grid.Column="2" VerticalAlignment="Center" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="{Binding SelectedSourceLanguage.Code, FallbackValue='auto'}"
                                       Foreground="{DynamicResource OvFgMutedBrush}" FontSize="11"
                                       VerticalAlignment="Center"
                                       ToolTip.Tip="Source language"/>
                            <TextBlock Text="→" Foreground="{DynamicResource OvFgTertiaryBrush}"
                                       FontSize="11" VerticalAlignment="Center"/>
                            <TextBlock Name="TargetLangLink"
                                       Text="{Binding SelectedTargetLanguage.Code, FallbackValue='--'}"
                                       Foreground="{StaticResource AccentBrush}" FontSize="11"
                                       Cursor="Hand" VerticalAlignment="Center"
                                       TextDecorations="Underline"
                                       ToolTip.Tip="Target language"/>
                            <Button Classes="iconBtn"
                                    Content="⇄" FontSize="15"
                                    Command="{Binding SwapLanguagesCommand}"
                                    ToolTip.Tip="Swap source ↔ target language"
                                    VerticalAlignment="Center"/>
                        </StackPanel>

                        <Popup Name="LangPopup"
                               IsOpen="{Binding IsLanguagePickerOpen, Mode=TwoWay}"
                               PlacementTarget="{Binding #TargetLangLink}"
                               Placement="Top"
                               IsLightDismissEnabled="True"
                               MaxHeight="260">
                            <Border Background="{StaticResource BgSurfaceBrush}" CornerRadius="8"
                                    BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                                    Padding="4" MinWidth="140">
                                <ScrollViewer MaxHeight="240"
                                              HorizontalScrollBarVisibility="Disabled">
                                    <ItemsControl ItemsSource="{Binding AvailableTargetLanguages}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Background="Transparent"
                                                        BorderThickness="0"
                                                        HorizontalContentAlignment="Stretch"
                                                        HorizontalAlignment="Stretch"
                                                        Padding="8,6" Cursor="Hand"
                                                        Command="{Binding $parent[Window].((vm:OverlayViewModel)DataContext).SelectLanguageCommand}"
                                                        CommandParameter="{Binding}">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <TextBlock Text="{Binding Code}"
                                                                   Foreground="{StaticResource FgPrimaryBrush}"
                                                                   FontSize="12" FontWeight="SemiBold"
                                                                   Width="28"/>
                                                        <TextBlock Text="{Binding DisplayName}"
                                                                   Foreground="{StaticResource FgMutedBrush}"
                                                                   FontSize="12"/>
                                                    </StackPanel>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Panel>

                    <Button Grid.Column="3" Classes="sendBtn"
                            Name="SendButton"
                            Content="Send ▶"
                            Click="SendButton_Click"
                            IsEnabled="{Binding TranslatedText,
                                        Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                            ToolTip.Tip="Send translation (Ctrl+Enter)"/>
                </Grid>
            </Grid>
        </Border>

        <!-- Resize grips (invisible edges + visible corner handle) -->
        <Border Name="ResizeN" Height="4" VerticalAlignment="Top" Background="Transparent" Cursor="SizeNorthSouth"/>
        <Border Name="ResizeS" Height="4" VerticalAlignment="Bottom" Background="Transparent" Cursor="SizeNorthSouth"/>
        <Border Name="ResizeW" Width="4" HorizontalAlignment="Left" Background="Transparent" Cursor="SizeWestEast"/>
        <Border Name="ResizeE" Width="4" HorizontalAlignment="Right" Background="Transparent" Cursor="SizeWestEast"/>
        <Border Name="ResizeNW" Width="8" Height="8" VerticalAlignment="Top" HorizontalAlignment="Left" Background="Transparent" Cursor="TopLeftCorner"/>
        <Border Name="ResizeNE" Width="8" Height="8" VerticalAlignment="Top" HorizontalAlignment="Right" Background="Transparent" Cursor="TopRightCorner"/>
        <Border Name="ResizeSW" Width="8" Height="8" VerticalAlignment="Bottom" HorizontalAlignment="Left" Background="Transparent" Cursor="BottomLeftCorner"/>
        <Panel Name="ResizeSE" Width="16" Height="16" VerticalAlignment="Bottom" HorizontalAlignment="Right" Cursor="BottomRightCorner">
            <TextBlock Text="⌟" FontSize="14" Foreground="{DynamicResource OvFgMutedBrush}"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       IsHitTestVisible="False"/>
        </Panel>
    </Panel>
</Window>
