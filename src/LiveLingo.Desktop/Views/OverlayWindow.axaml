<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:LiveLingo.Desktop.ViewModels"
        x:Class="LiveLingo.Desktop.Views.OverlayWindow"
        x:DataType="vm:OverlayViewModel"
        WindowDecorations="None"
        Topmost="True"
        CanResize="True"
        ShowInTaskbar="False"
        UseLayoutRounding="True"
        Background="Transparent"
        TransparencyLevelHint="Transparent"
        Width="600"
        SizeToContent="Height"
        MinWidth="320" MinHeight="260" MaxHeight="600"
        WindowStartupLocation="Manual">

    <Window.Resources>
        <SolidColorBrush x:Key="OvFrameBrush" Color="#D91C1C1E"/>
        <SolidColorBrush x:Key="OvPanelBrush" Color="#1C1C1E"/>
        <SolidColorBrush x:Key="OvFgPrimaryBrush" Color="#E5E5E7"/>
        <SolidColorBrush x:Key="OvFgSecondaryBrush" Color="#C7C7CC"/>
        <SolidColorBrush x:Key="OvFgTertiaryBrush" Color="#AEAEB2"/>
        <SolidColorBrush x:Key="OvFgMutedBrush" Color="#A1A1A6"/>
    </Window.Resources>

    <Window.Styles>
        <Style Selector="TextBox.source">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource OvFgPrimaryBrush}"/>
            <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="12,8,12,4"/>
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="PlaceholderText" Value=""/>
        </Style>
        <Style Selector="TextBox.source:pointerover /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="TextBox.source:focus /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="SelectableTextBlock.translation">
            <Setter Property="Foreground" Value="{DynamicResource OvFgSecondaryBrush}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Padding" Value="12,6"/>
        </Style>
        <Style Selector="TextBlock.status">
            <Setter Property="Foreground" Value="{DynamicResource OvFgTertiaryBrush}"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
        <Style Selector="TextBlock.modelStatus">
            <Setter Property="Foreground" Value="{DynamicResource OvFgMutedBrush}"/>
            <Setter Property="FontSize" Value="10"/>
        </Style>
        <Style Selector="Button.sendBtn">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="MinHeight" Value="0"/>
        </Style>
        <Style Selector="Button.sendBtn:disabled">
            <Setter Property="Opacity" Value="0.4"/>
        </Style>
        <Style Selector="Button.iconBtn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="7,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinWidth" Value="28"/>
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="Foreground" Value="{DynamicResource OvFgSecondaryBrush}"/>
            <Setter Property="FontSize" Value="17"/>
        </Style>
        <Style Selector="Popup Button:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource BgElevatedBrush}"/>
            <Setter Property="CornerRadius" Value="4"/>
        </Style>
        <Style Selector="Button.copyBtn">
            <Setter Property="Background" Value="{StaticResource BgElevatedBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource OvFgSecondaryBrush}"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style Selector="Border#ResizeSE:pointerover">
            <Setter Property="Opacity" Value="1"/>
        </Style>
        <Style Selector="Border#ResizeSE:pressed">
            <Setter Property="Opacity" Value="0.85"/>
        </Style>
        <Style Selector="Border#TargetLangLink:pointerover">
            <Setter Property="Background" Value="#1AFFFFFF"/>
        </Style>
        <Style Selector="Border#TargetLangLink:pressed">
            <Setter Property="Background" Value="#26FFFFFF"/>
        </Style>
        <Style Selector="Border#SourceLangBadge:pointerover">
            <Setter Property="Background" Value="#12FFFFFF"/>
        </Style>
    </Window.Styles>

    <Panel Name="RootPanel" Opacity="0">
        <Panel.Transitions>
            <Transitions>
                <DoubleTransition Property="Opacity" Duration="0:0:0.15"/>
            </Transitions>
        </Panel.Transitions>

        <Border Name="AcrylicBg" CornerRadius="12" IsHitTestVisible="False" Background="{DynamicResource OvFrameBrush}"/>
        <Border CornerRadius="12" IsHitTestVisible="False"
                BorderBrush="#15FFFFFF" BorderThickness="1"/>

        <Border CornerRadius="12" Padding="0">
            <Grid RowDefinitions="Auto,Auto,*,Auto">

                <!-- Title bar -->
                <Border Grid.Row="0" Name="DragHandle"
                        Background="Transparent" Cursor="Hand"
                        Height="28" CornerRadius="12,12,0,0">
                    <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                        <TextBlock Grid.Column="1" Text="{Binding AppTitle}"
                                   FontSize="11" Foreground="{DynamicResource OvFgTertiaryBrush}"
                                   Margin="0,0,4,0" VerticalAlignment="Center"/>
                        <Button Grid.Column="2" Classes="iconBtn"
                                Content="⚙" FontSize="17"
                                Command="{Binding OpenSettingsCommand}"
                                ToolTip.Tip="{Binding SettingsTooltip}"
                                Margin="0,0,2,0" VerticalAlignment="Center"/>
                        <Button Grid.Column="3" Content="✕"
                                Click="CloseButton_Click"
                                FontSize="14" Foreground="{DynamicResource OvFgSecondaryBrush}"
                                Background="Transparent" BorderThickness="0"
                                Padding="6,2" Margin="0,0,8,0"
                                VerticalAlignment="Center" Cursor="Hand"
                                ToolTip.Tip="{Binding CloseTooltip}"
                                MinWidth="0" MinHeight="0"/>
                    </Grid>
                </Border>

                <!-- Loading indicator -->
                <ProgressBar Grid.Row="1" IsIndeterminate="True"
                             IsVisible="{Binding IsTranslating}"
                             Height="2" Margin="14,4,14,0"
                             Foreground="{StaticResource AccentBrush}"
                             Background="{StaticResource BgSurfaceBrush}"/>

                <Grid Grid.Row="2"
                      RowDefinitions="120,*"
                      RowSpacing="8"
                      Margin="14,8,14,0"
                      MinHeight="0"
                      ClipToBounds="True">
                    <!-- Source input with embedded toolbar -->
                    <Border Grid.Row="0" Height="120"
                            CornerRadius="8"
                            Background="{DynamicResource OvPanelBrush}"
                            ClipToBounds="True">
                        <Grid RowDefinitions="*,Auto">
                            <TextBox Grid.Row="0" Classes="source"
                                     Text="{Binding SourceText, Mode=TwoWay}"
                                     PlaceholderText="{Binding SourceHint}"
                                     Name="SourceInput"
                                     VerticalAlignment="Stretch"/>

                            <!-- Inner toolbar -->
                            <Grid Grid.Row="1" ColumnDefinitions="Auto,Auto,*,Auto,Auto"
                                  Margin="6,0,6,4" Height="26">

                                <!-- Character count (left) -->
                                <TextBlock Grid.Column="0"
                                           Text="{Binding SourceTextLength}"
                                           FontSize="10"
                                           Foreground="{DynamicResource OvFgMutedBrush}"
                                           VerticalAlignment="Center"
                                           Margin="6,0,4,0"
                                           IsHitTestVisible="False"/>

                                <!-- Voice status + download link (left, after count) -->
                                <StackPanel Grid.Column="1" Orientation="Horizontal"
                                            Spacing="4" VerticalAlignment="Center"
                                            IsVisible="{Binding !IsRecording}">
                                    <TextBlock Text="{Binding VoiceStatusText}"
                                               FontSize="11"
                                               Foreground="{StaticResource AccentBrush}"
                                               VerticalAlignment="Center"
                                               IsVisible="{Binding VoiceStatusText,
                                                           Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                    <Button Command="{Binding DownloadSttModelCommand}"
                                            IsVisible="{Binding ShowSttDownloadLink}"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Padding="2,0"
                                            Cursor="Hand"
                                            MinWidth="0" MinHeight="0"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{Binding DownloadModelLabel}"
                                                   FontSize="11"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   TextDecorations="Underline"/>
                                    </Button>
                                </StackPanel>

                                <!-- Voice language picker (right, next to mic, recording only) -->
                                <Panel Grid.Column="3" VerticalAlignment="Center"
                                       Margin="0,0,4,0"
                                       IsVisible="{Binding IsRecording}">
                                    <Border Name="VoiceLangBadge"
                                            Padding="6,2"
                                            CornerRadius="4"
                                            Background="#12FFFFFF"
                                            Cursor="Hand"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{Binding VoiceLanguageDisplay}"
                                                   Foreground="{StaticResource AccentBrush}" FontSize="11"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <Popup Name="VoiceLangPopup"
                                           IsOpen="{Binding IsVoiceLanguagePickerOpen, Mode=TwoWay}"
                                           PlacementTarget="{Binding #VoiceLangBadge}"
                                           Placement="Top"
                                           IsLightDismissEnabled="True"
                                           MaxHeight="260">
                                        <Border Background="{StaticResource BgSurfaceBrush}" CornerRadius="8"
                                                BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                                                Padding="4" MinWidth="140">
                                            <ScrollViewer MaxHeight="240"
                                                          HorizontalScrollBarVisibility="Disabled">
                                                <ItemsControl ItemsSource="{Binding AvailableVoiceLanguages}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Button Background="Transparent"
                                                                    BorderThickness="0"
                                                                    HorizontalContentAlignment="Stretch"
                                                                    HorizontalAlignment="Stretch"
                                                                    Padding="8,6" Cursor="Hand"
                                                                    Command="{Binding $parent[Window].((vm:OverlayViewModel)DataContext).SelectVoiceLanguageCommand}"
                                                                    CommandParameter="{Binding}">
                                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                                    <TextBlock Text="{Binding Code}"
                                                                               Foreground="{StaticResource FgPrimaryBrush}"
                                                                               FontSize="12" FontWeight="SemiBold"
                                                                               Width="28"/>
                                                                    <TextBlock Text="{Binding DisplayName}"
                                                                               Foreground="{StaticResource FgMutedBrush}"
                                                                               FontSize="12"/>
                                                                </StackPanel>
                                                            </Button>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>
                                        </Border>
                                    </Popup>
                                </Panel>

                                <!-- Microphone button (rightmost) -->
                                <Button Grid.Column="4"
                                        Name="MicButton"
                                        Command="{Binding ToggleVoiceInputCommand}"
                                        IsVisible="{Binding IsVoiceAvailable}"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Padding="4"
                                        Cursor="Hand"
                                        MinWidth="24" MinHeight="24"
                                        VerticalAlignment="Center"
                                        ToolTip.Tip="{Binding VoiceTooltip}">
                                    <Panel Width="16" Height="16">
                                        <!-- Mic icon (idle/error) -->
                                        <Path Data="M8,1 C9.657,1 11,2.343 11,4 L11,8 C11,9.657 9.657,11 8,11 C6.343,11 5,9.657 5,8 L5,4 C5,2.343 6.343,1 8,1 Z M13,8 C13,10.419 11.171,12.377 8.8,12.826 L8.8,15 L7.2,15 L7.2,12.826 C4.829,12.377 3,10.419 3,8 L4.2,8 C4.2,10.098 5.902,11.8 8,11.8 C10.098,11.8 11.8,10.098 11.8,8 Z"
                                              Fill="{DynamicResource OvFgMutedBrush}"
                                              Stretch="Uniform"
                                              Width="16" Height="16"
                                              Name="MicIconIdle"/>
                                        <!-- Stop icon (recording - red square) -->
                                        <Border Width="12" Height="12"
                                                Background="#FF453A"
                                                CornerRadius="2"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Name="StopIconRecording"
                                                IsVisible="False"/>
                                    </Panel>
                                </Button>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- Translation result -->
                    <Border Grid.Row="1" Name="TranslationBorder"
                            CornerRadius="8" Background="{DynamicResource OvPanelBrush}"
                            MinHeight="120"
                            VerticalAlignment="Stretch">
                        <Grid ColumnDefinitions="*,Auto">
                            <ScrollViewer Grid.Column="0"
                                          VerticalAlignment="Stretch"
                                          HorizontalScrollBarVisibility="Disabled"
                                          VerticalScrollBarVisibility="Auto">
                                <SelectableTextBlock Classes="translation"
                                                     Text="{Binding TranslatedText}"/>
                            </ScrollViewer>
                            <StackPanel Grid.Column="1" VerticalAlignment="Top" Margin="0,4,4,0">
                                <Button Classes="copyBtn"
                                        Command="{Binding CopyTranslationCommand}"
                                        IsEnabled="{Binding TranslatedText,
                                                    Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                    <Panel>
                                        <TextBlock Text="{Binding CopyLabel}"
                                                   IsVisible="{Binding !ShowCopiedFeedback}"/>
                                        <TextBlock Text="{Binding CopiedLabel}"
                                                   Foreground="{StaticResource SuccessBrush}"
                                                   IsVisible="{Binding ShowCopiedFeedback}"/>
                                    </Panel>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Bottom bar -->
                <Grid Grid.Row="3" Margin="14,8,14,12" MinHeight="30"
                      ColumnDefinitions="Auto,*,Auto,Auto">
                    <StackPanel Grid.Column="0" Spacing="1" VerticalAlignment="Center">
                        <TextBlock Classes="modelStatus"
                                   Text="{Binding ActiveModelLabel}"
                                   ToolTip.Tip="{Binding ActiveModelTooltip}"/>
                        <TextBlock Classes="status"
                                   Text="{Binding StatusText}"/>
                    </StackPanel>

                    <Panel Grid.Column="2" VerticalAlignment="Center" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <Border Name="SourceLangBadge"
                                    Padding="6,2"
                                    CornerRadius="4"
                                    Background="Transparent"
                                    VerticalAlignment="Center">
                                <TextBlock Text="{Binding SourceLanguageCodeDisplay}"
                                           Foreground="{DynamicResource OvFgMutedBrush}" FontSize="12"
                                           VerticalAlignment="Center"
                                           ToolTip.Tip="{Binding SourceLanguageTooltip}"/>
                            </Border>
                            <TextBlock Text="→" Foreground="{DynamicResource OvFgTertiaryBrush}"
                                       FontSize="12" VerticalAlignment="Center"/>
                            <Border Name="TargetLangLink"
                                    Padding="6,2"
                                    CornerRadius="4"
                                    Background="Transparent"
                                    Cursor="Hand"
                                    VerticalAlignment="Center"
                                    ToolTip.Tip="{Binding TargetLanguageTooltip}">
                                <TextBlock Text="{Binding SelectedTargetLanguage.Code, FallbackValue='--'}"
                                           Foreground="{StaticResource AccentBrush}" FontSize="12"
                                           TextDecorations="Underline"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <Button Classes="iconBtn"
                                    Content="⇄" FontSize="17"
                                    Command="{Binding SwapLanguagesCommand}"
                                    ToolTip.Tip="{Binding SwapLanguagesTooltip}"
                                    VerticalAlignment="Center"/>
                        </StackPanel>

                        <Popup Name="LangPopup"
                               IsOpen="{Binding IsLanguagePickerOpen, Mode=TwoWay}"
                               PlacementTarget="{Binding #TargetLangLink}"
                               Placement="Top"
                               IsLightDismissEnabled="True"
                               MaxHeight="260">
                            <Border Background="{StaticResource BgSurfaceBrush}" CornerRadius="8"
                                    BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                                    Padding="4" MinWidth="140">
                                <ScrollViewer MaxHeight="240"
                                              HorizontalScrollBarVisibility="Disabled">
                                    <ItemsControl ItemsSource="{Binding AvailableTargetLanguages}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Background="Transparent"
                                                        BorderThickness="0"
                                                        HorizontalContentAlignment="Stretch"
                                                        HorizontalAlignment="Stretch"
                                                        Padding="8,6" Cursor="Hand"
                                                        Command="{Binding $parent[Window].((vm:OverlayViewModel)DataContext).SelectLanguageCommand}"
                                                        CommandParameter="{Binding}">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <TextBlock Text="{Binding Code}"
                                                                   Foreground="{StaticResource FgPrimaryBrush}"
                                                                   FontSize="12" FontWeight="SemiBold"
                                                                   Width="28"/>
                                                        <TextBlock Text="{Binding DisplayName}"
                                                                   Foreground="{StaticResource FgMutedBrush}"
                                                                   FontSize="12"/>
                                                    </StackPanel>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Panel>

                    <Button Grid.Column="3" Classes="sendBtn"
                            Name="SendButton"
                            Content="{Binding SendLabel}"
                            Click="SendButton_Click"
                            IsEnabled="{Binding TranslatedText,
                                        Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                            ToolTip.Tip="{Binding SendTooltip}"/>
                </Grid>
            </Grid>
        </Border>

        <Border Name="ResizeSE"
                Width="24"
                Height="24"
                Margin="0,0,2,2"
                Background="Transparent"
                CornerRadius="0,0,10,0"
                Opacity="0.72"
                VerticalAlignment="Bottom"
                HorizontalAlignment="Right"
                Cursor="BottomRightCorner">
            <Border.Transitions>
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.12"/>
                </Transitions>
            </Border.Transitions>
            <Grid Width="12"
                  Height="12"
                  Margin="0,0,3,3"
                  HorizontalAlignment="Right"
                  VerticalAlignment="Bottom"
                  IsHitTestVisible="False">
                <Border Width="4"
                        Height="1"
                        Margin="0,0,0,8"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Background="{DynamicResource OvFgMutedBrush}"/>
                <Border Width="8"
                        Height="1"
                        Margin="0,0,0,4"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Background="{DynamicResource OvFgMutedBrush}"/>
                <Border Width="12"
                        Height="1"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Background="{DynamicResource OvFgMutedBrush}"/>
            </Grid>
        </Border>
    </Panel>
</Window>
