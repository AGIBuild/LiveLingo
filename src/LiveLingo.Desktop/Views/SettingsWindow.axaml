<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:LiveLingo.Desktop.ViewModels"
        xmlns:ctrl="using:LiveLingo.Desktop.Controls"
        x:Class="LiveLingo.Desktop.Views.SettingsWindow"
        x:DataType="vm:SettingsViewModel"
        Title="LiveLingo Settings"
        Width="540" Height="520"
        CanResize="False"
        WindowStartupLocation="CenterScreen"
        TransparencyLevelHint="AcrylicBlur"
        Background="Transparent"
        WindowDecorations="None">

    <Panel>
        <Border Name="BgBorder" IsHitTestVisible="False"
                Background="#D91C1C1E" CornerRadius="8"/>

        <Border IsHitTestVisible="False"
                BorderBrush="#15FFFFFF" BorderThickness="1"
                CornerRadius="8"/>

        <DockPanel Margin="24,24,24,20">
            <TextBlock DockPanel.Dock="Top" Name="TitleText" Text="Settings"
                       FontSize="18" FontWeight="SemiBold"
                       Foreground="{StaticResource FgPrimaryBrush}"
                       Margin="0,0,0,14"/>

            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                        HorizontalAlignment="Right" Spacing="8" Margin="0,14,0,0">
                <Button Name="ResetBtn" Content="Reset Defaults" Command="{Binding ResetCommand}"
                        Padding="14,7" Classes="themed"/>
                <Button Name="CancelBtn" Content="Cancel" Command="{Binding CancelCommand}"
                        Padding="14,7" Classes="themed"/>
                <Button Name="SaveBtn" Content="Save" Command="{Binding SaveCommand}"
                        Padding="14,7" IsDefault="True" Classes="accent"/>
            </StackPanel>

            <TabControl SelectedIndex="{Binding SelectedTabIndex}">
                <!-- General -->
                <TabItem Name="TabGeneral" Header="General" Classes="themed">
                    <ScrollViewer>
                        <StackPanel Spacing="2" Margin="0,4">
                            <TextBlock Classes="section" Text="{Binding GeneralSectionHotkeys}"/>
                            <Grid ColumnDefinitions="130,*">
                                <TextBlock Classes="label" Text="{Binding GeneralOverlayToggleLabel}"/>
                                <ctrl:HotkeyRecorder Grid.Column="1"
                                    Hotkey="{Binding WorkingCopy.Hotkeys.OverlayToggle, Mode=TwoWay}"/>
                            </Grid>
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,3,0,0">
                                <TextBlock Classes="hint" Text="{Binding GeneralHotkeyHint}"/>
                                <Button Content="{Binding GeneralCheckPermissions}" Classes="themed sm"
                                        Command="{Binding CheckPermissionsCommand}"
                                        IsVisible="{Binding ShowPermissionSection}"
                                        Padding="8,3" VerticalAlignment="Center"/>
                            </StackPanel>

                            <Separator Classes="themed"/>
                            <TextBlock Classes="section" Text="{Binding GeneralSectionOverlay}"/>
                            <Grid ColumnDefinitions="130,*" RowDefinitions="Auto,Auto" RowSpacing="10">
                                <TextBlock Classes="label" Text="{Binding GeneralOpacityLabel}"/>
                                <Grid Grid.Column="1" ColumnDefinitions="*,36">
                                    <Slider Classes="themed" Minimum="0.1" Maximum="1.0"
                                            Value="{Binding WorkingCopy.UI.OverlayOpacity}"
                                            TickFrequency="0.05" IsSnapToTickEnabled="True"/>
                                    <TextBlock Grid.Column="1" VerticalAlignment="Center"
                                               HorizontalAlignment="Right" FontSize="11"
                                               Foreground="{StaticResource FgTertiaryBrush}">
                                        <TextBlock.Text>
                                            <Binding Path="WorkingCopy.UI.OverlayOpacity" StringFormat="{}{0:P0}"/>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </Grid>
                                <TextBlock Grid.Row="1" Classes="label" Text="{Binding GeneralInjectionModeLabel}"/>
                                <ComboBox Grid.Row="1" Grid.Column="1" MinWidth="160"
                                          Classes="themed"
                                          ItemsSource="{Binding InjectionModeOptions}"
                                          SelectedValueBinding="{Binding Value}"
                                          SelectedValue="{Binding WorkingCopy.UI.DefaultInjectionMode}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="vm:SelectableOption">
                                            <TextBlock Text="{Binding DisplayName}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </Grid>
                            <Separator Classes="themed"/>
                            <TextBlock Classes="section" Text="{Binding GeneralSectionLanguage}"/>
                            <Grid ColumnDefinitions="130,*">
                                <TextBlock Classes="label" Text="{Binding GeneralUiLanguageLabel}"/>
                                <ComboBox Grid.Column="1" MinWidth="160"
                                          Classes="themed"
                                          ItemsSource="{Binding UILanguages}"
                                          SelectedValueBinding="{Binding Code}"
                                          SelectedValue="{Binding WorkingCopy.UI.Language}"/>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- Translation -->
                <TabItem Name="TabTranslation" Header="Translation" Classes="themed">
                    <ScrollViewer>
                        <StackPanel Spacing="2" Margin="0,4">
                            <TextBlock Classes="section" Text="{Binding TranslationSectionDefaultPair}"/>
                            <Grid ColumnDefinitions="130,*" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="10">
                                <TextBlock Classes="label" Text="{Binding TranslationSourceLabel}"/>
                                <ComboBox Grid.Column="1" MinWidth="200"
                                          Classes="themed"
                                          ItemsSource="{Binding AvailableLanguages}"
                                          SelectedValueBinding="{Binding Code}"
                                          SelectedValue="{Binding WorkingCopy.Translation.DefaultSourceLanguage}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding DisplayName}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <TextBlock Grid.Row="1" Classes="label" Text="{Binding TranslationTargetLabel}"/>
                                <ComboBox Grid.Row="1" Grid.Column="1" MinWidth="200"
                                          Classes="themed"
                                          ItemsSource="{Binding AvailableLanguages}"
                                          SelectedValueBinding="{Binding Code}"
                                          SelectedValue="{Binding WorkingCopy.Translation.DefaultTargetLanguage}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding DisplayName}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <TextBlock Grid.Row="2" Classes="label" Text="{Binding TranslationActiveModelLabel}"/>
                                <Grid Grid.Row="2" Grid.Column="1" ColumnDefinitions="*,Auto" ColumnSpacing="6">
                                    <ComboBox MinWidth="260"
                                              Classes="themed"
                                              ItemsSource="{Binding AvailableTranslationModels}"
                                              SelectedValueBinding="{Binding Id}"
                                              SelectedValue="{Binding WorkingCopy.Translation.ActiveTranslationModelId}">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate x:DataType="vm:TranslationModelOption">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <TextBlock Text="{Binding DisplayName}"/>
                                                    <TextBlock Text="{Binding PairLabel}" Foreground="{StaticResource FgTertiaryBrush}"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                    <Button Grid.Column="1"
                                            Content="↻"
                                            Classes="themed sm"
                                            Command="{Binding RefreshTranslationModelsCommand}"
                                            ToolTip.Tip="{Binding TranslationRefreshModelsTooltip}"
                                            Padding="10,6"/>
                                </Grid>
                                <StackPanel Grid.Row="3" Grid.Column="1"
                                            Orientation="Horizontal"
                                            Spacing="8"
                                            IsVisible="{Binding ShowNoInstalledModelsHint}">
                                    <TextBlock Classes="hint"
                                               Foreground="{StaticResource FgTertiaryBrush}"
                                               VerticalAlignment="Center"
                                               Text="{Binding TranslationNoInstalledModelsHint}"/>
                                    <Button Command="{Binding OpenModelsTabCommand}"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Padding="0"
                                            Cursor="Hand"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{Binding TranslationOpenModelsTab}"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   TextDecorations="Underline"/>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- Models -->
                <TabItem Name="TabModels" Header="Models" Classes="themed">
                    <ScrollViewer>
                        <StackPanel Spacing="8" Margin="0,4">
                            <TextBlock Classes="hint" Text="{Binding ModelsHuggingFaceHint}" TextWrapping="Wrap"/>
                            <Button HorizontalAlignment="Left" Padding="10,6" Classes="themed sm"
                                    Content="{Binding ModelsOpenAdvancedForTokenLabel}"
                                    Command="{Binding OpenAdvancedTabForTokenCommand}"/>
                        <ItemsControl ItemsSource="{Binding Models}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:ModelItemViewModel">
                                    <Border Margin="0,0,0,6" Padding="12,10"
                                            CornerRadius="8" Background="{StaticResource BgSurfaceBrush}">
                                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <Border Background="#200A84FF" CornerRadius="4" Padding="6,2">
                                                    <TextBlock Text="{Binding TypeLabel}"
                                                               FontSize="10" Foreground="{StaticResource AccentBrush}"/>
                                                </Border>
                                                <TextBlock Text="{Binding DisplayName}"
                                                           Foreground="#FFFFFF" FontSize="13"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                                                <Button Classes="themed sm"
                                                        Content="{Binding OpenOnHuggingFaceLabel}"
                                                        Command="{Binding OpenOnHuggingFaceCommand}"
                                                        IsVisible="{Binding ShowOpenOnHuggingFace}"/>
                                                <Button Classes="accent sm"
                                                        Content="{Binding DownloadButtonLabel}"
                                                        Command="{Binding DownloadCommand}"
                                                        IsVisible="{Binding !IsInstalled}"/>
                                                <Button Classes="themed sm"
                                                        Content="{Binding CancelButtonLabel}"
                                                        Command="{Binding CancelDownloadCommand}"
                                                        IsVisible="{Binding IsDownloading}"/>
                                                <TextBlock Text="{Binding InstalledLabel}" FontSize="11"
                                                           Foreground="{StaticResource SuccessBrush}"
                                                           VerticalAlignment="Center"
                                                           IsVisible="{Binding IsInstalled}"/>
                                                <Button Classes="danger sm"
                                                        Content="{Binding DeleteButtonLabel}"
                                                        Command="{Binding DeleteCommand}"
                                                        IsVisible="{Binding IsInstalled}"/>
                                            </StackPanel>

                                            <StackPanel Grid.Row="1" Grid.ColumnSpan="2"
                                                        Orientation="Horizontal" Spacing="12"
                                                        Margin="0,4,0,0">
                                                <TextBlock Text="{Binding SizeText}"
                                                           FontSize="11" Foreground="{StaticResource FgTertiaryBrush}"/>
                                                <TextBlock Text="{Binding ErrorMessage}"
                                                           FontSize="11" Foreground="{StaticResource DangerBrush}"
                                                           IsVisible="{Binding ErrorMessage,
                                                               Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                            </StackPanel>

                                            <ProgressBar Grid.Row="2" Grid.ColumnSpan="2"
                                                         Classes="themed"
                                                         Margin="0,6,0,0"
                                                         Minimum="0" Maximum="100"
                                                         Value="{Binding DownloadProgress}"
                                                         IsVisible="{Binding IsDownloading}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- Advanced -->
                <TabItem Name="TabAdvanced" Header="Advanced" Classes="themed">
                    <ScrollViewer>
                        <StackPanel Spacing="2" Margin="0,4">
                            <TextBlock Classes="section" Text="{Binding AdvancedSectionModelStorage}"/>
                            <Grid ColumnDefinitions="130,*,Auto">
                                <TextBlock Classes="label" Text="{Binding AdvancedStoragePathLabel}"/>
                                <TextBox Grid.Column="1" Classes="themed"
                                         Text="{Binding WorkingCopy.Advanced.ModelStoragePath}"
                                         PlaceholderText="{Binding AdvancedStoragePathPlaceholder}"/>
                                <Button Grid.Column="2" Content="{Binding AdvancedBrowseLabel}"
                                        Click="BrowseModelPath_Click"
                                        Margin="6,0,0,0" Padding="10,6"
                                        Classes="themed sm"/>
                            </Grid>
                            <TextBlock FontSize="11" Foreground="{StaticResource DangerBrush}"
                                       Text="{Binding MigrationError}"
                                       IsVisible="{Binding MigrationError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                       Margin="0,3,0,0"/>
                            <Separator Classes="themed"/>
                            <TextBlock Classes="section" Text="{Binding AdvancedSectionHuggingFace}"/>
                            <Grid ColumnDefinitions="130,*">
                                <TextBlock Classes="label" Text="{Binding AdvancedHuggingFaceMirrorLabel}"/>
                                <TextBox Grid.Column="1" Classes="themed"
                                         Text="{Binding WorkingCopy.Advanced.HuggingFaceMirror}"
                                         PlaceholderText="{Binding AdvancedHuggingFaceMirrorPlaceholder}"/>
                            </Grid>
                            <Grid ColumnDefinitions="130,*">
                                <TextBlock Classes="label" Text="{Binding AdvancedHuggingFaceTokenLabel}"/>
                                <TextBox Grid.Column="1" Classes="themed"
                                         PasswordChar="*"
                                         Text="{Binding WorkingCopy.Advanced.HuggingFaceToken, Mode=TwoWay}"/>
                            </Grid>
                            <TextBlock Classes="hint" Text="{Binding AdvancedHuggingFaceTokenHint}" TextWrapping="Wrap"/>
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,6,0,0"
                                        IsVisible="{Binding ShowAdvancedHuggingFaceBrowserLinks}">
                                <Button Padding="10,6" Classes="themed sm"
                                        Content="{Binding AdvancedOpenHuggingFaceTokensLabel}"
                                        Command="{Binding OpenHuggingFaceTokenSettingsPageCommand}"/>
                                <Button Padding="10,6" Classes="themed sm"
                                        Content="{Binding AdvancedOpenTranslationModelLabel}"
                                        Command="{Binding OpenPrimaryTranslationModelOnHuggingFaceCommand}"/>
                            </StackPanel>
                            <Separator Classes="themed"/>
                            <TextBlock Classes="section" Text="{Binding AdvancedSectionPerformance}"/>
                            <Grid ColumnDefinitions="130,*">
                                <TextBlock Classes="label" Text="{Binding AdvancedInferenceThreadsLabel}"/>
                                <NumericUpDown Grid.Column="1" Minimum="0" Maximum="32"
                                               Classes="themed"
                                               Value="{Binding WorkingCopy.Advanced.InferenceThreads}"
                                               MinWidth="100" HorizontalAlignment="Left"/>
                            </Grid>
                            <TextBlock Classes="hint" Text="{Binding AdvancedThreadsHint}"/>
                            <Separator Classes="themed"/>
                            <TextBlock Classes="section" Text="{Binding AdvancedSectionLogging}"/>
                            <Grid ColumnDefinitions="130,*">
                                <TextBlock Classes="label" Text="{Binding AdvancedLogLevelLabel}"/>
                                <ComboBox Grid.Column="1" MinWidth="160"
                                          Classes="themed"
                                          ItemsSource="{Binding LogLevelOptions}"
                                          SelectedValueBinding="{Binding Value}"
                                          SelectedValue="{Binding WorkingCopy.Advanced.LogLevel}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="vm:SelectableOption">
                                            <TextBlock Text="{Binding DisplayName}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- AI -->
                <TabItem Name="TabAI" Header="AI" Classes="themed">
                    <ScrollViewer>
                        <StackPanel Spacing="2" Margin="0,4">
                            <TextBlock Classes="section" Text="{Binding AiSectionPostProcessing}"/>
                            <Grid ColumnDefinitions="130,*">
                                <TextBlock Classes="label" Text="{Binding AiDefaultModeLabel}"/>
                                <ComboBox Grid.Column="1" MinWidth="160"
                                          Classes="themed"
                                          ItemsSource="{Binding PostProcessModeOptions}"
                                          SelectedValueBinding="{Binding Value}"
                                          SelectedValue="{Binding WorkingCopy.Processing.DefaultMode}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="vm:SelectableOption">
                                            <TextBlock Text="{Binding DisplayName}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </Grid>
                            <TextBlock Classes="hint"
                                       Text="{Binding AiModesHint}"/>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </DockPanel>

        <Border Name="DragHandle"
                Height="38"
                Margin="8,8,8,0"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Top"
                Background="Transparent"
                Cursor="Hand"/>
    </Panel>
</Window>
