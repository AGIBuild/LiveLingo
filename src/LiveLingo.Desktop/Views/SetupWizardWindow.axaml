<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:LiveLingo.Desktop.ViewModels"
        x:Class="LiveLingo.Desktop.Views.SetupWizardWindow"
        x:DataType="vm:SetupWizardViewModel"
        Title="{Binding WindowTitle}"
        Width="480" SizeToContent="Height"
        CanResize="False"
        WindowStartupLocation="CenterScreen"
        TransparencyLevelHint="AcrylicBlur"
        Background="Transparent"
        WindowDecorations="None">

    <Window.Styles>
        <Style Selector="ProgressBar.wizard">
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Background" Value="{StaticResource BgSurfaceBrush}"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="MinHeight" Value="6"/>
            <Setter Property="MaxHeight" Value="6"/>
        </Style>
    </Window.Styles>

    <Panel>
        <Border IsHitTestVisible="False" Background="#D91C1C1E" CornerRadius="8"/>
        <Border IsHitTestVisible="False"
                BorderBrush="#15FFFFFF" BorderThickness="1"
                CornerRadius="8"/>
        <Border Name="DragHandle" Height="30" Background="Transparent"
                VerticalAlignment="Top" Cursor="Hand"/>

        <DockPanel Margin="32,40,32,24">
            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                        HorizontalAlignment="Right" Spacing="8" Margin="0,20,0,0">
                <Button Content="{Binding BackButtonLabel}" Command="{Binding GoBackCommand}"
                        IsEnabled="{Binding CanGoBack}" Padding="20,8" Classes="themed"/>
                <Button Content="{Binding NextButtonLabel}" Command="{Binding GoNextCommand}"
                        IsVisible="{Binding !IsLastStep}" Padding="20,8" Classes="themed"/>
                <Button Content="{Binding FinishButtonLabel}" Command="{Binding FinishCommand}"
                        IsVisible="{Binding IsLastStep}" Padding="20,8"
                        IsDefault="True" Classes="accent"/>
            </StackPanel>

            <Border DockPanel.Dock="Top" Background="#150A84FF" CornerRadius="10"
                    Padding="10,4" HorizontalAlignment="Left" Margin="0,0,0,20">
                <TextBlock FontSize="11" Foreground="{StaticResource AccentBrush}"
                           Text="{Binding StepIndicator}"/>
            </Border>

            <Grid>
                <!-- Step 0: Languages -->
                <StackPanel IsVisible="{Binding IsStep0}" Spacing="8">
                    <TextBlock Classes="heading" Text="{Binding Step0Title}"/>
                    <TextBlock Classes="desc"
                               Text="{Binding Step0Description}"/>
                    <Grid ColumnDefinitions="100,*" RowDefinitions="Auto,Auto" RowSpacing="12">
                        <TextBlock Classes="label" Text="{Binding Step0SourceLabel}"/>
                        <ComboBox Grid.Column="1" MinWidth="220"
                                  Classes="themed"
                                  ItemsSource="{Binding AvailableLanguages}"
                                  SelectedItem="{Binding SelectedSourceLanguage}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DisplayName}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <TextBlock Grid.Row="1" Classes="label" Text="{Binding Step0TargetLabel}"/>
                        <ComboBox Grid.Row="1" Grid.Column="1" MinWidth="220"
                                  Classes="themed"
                                  ItemsSource="{Binding AvailableLanguages}"
                                  SelectedItem="{Binding SelectedTargetLanguage}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DisplayName}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </Grid>
                </StackPanel>

                <!-- Step 1: Hotkey -->
                <StackPanel IsVisible="{Binding IsStep1}" Spacing="8">
                    <TextBlock Classes="heading" Text="{Binding Step1Title}"/>
                    <TextBlock Classes="desc"
                               Text="{Binding Step1Description}"/>
                    <Grid ColumnDefinitions="100,*">
                        <TextBlock Classes="label" Text="{Binding Step1HotkeyLabel}"/>
                        <TextBox Grid.Column="1" Classes="themed"
                                 Text="{Binding OverlayHotkey}"
                                 FontSize="16" FontWeight="SemiBold"/>
                    </Grid>
                </StackPanel>

                <!-- Step 2: Model Download -->
                <StackPanel IsVisible="{Binding IsStep2}" Spacing="8">
                    <TextBlock Classes="heading" Text="{Binding Step2Title}"/>
                    <TextBlock Classes="desc"
                               Text="{Binding Step2Description}" TextWrapping="Wrap"/>
                    <TextBlock Classes="hint" Text="{Binding Step2HuggingFaceIntroHint}" TextWrapping="Wrap"/>
                    <Button HorizontalAlignment="Left" Padding="10,6" Classes="themed sm"
                            Content="{Binding Step2OpenModelOnHuggingFaceLabel}"
                            Command="{Binding OpenRequiredModelOnHuggingFaceCommand}"
                            IsVisible="{Binding ShowOpenRequiredModelOnHuggingFace}"/>
                    <Border Padding="10,8" CornerRadius="6"
                            Background="#25FF9F0A"
                            BorderBrush="#40FF9F0A" BorderThickness="1"
                            IsVisible="{Binding ShowHuggingFaceTokenMissingCallout}">
                        <StackPanel Spacing="8">
                            <TextBlock Text="{Binding Step2HuggingFaceTokenMissingHint}"
                                       FontSize="11" TextWrapping="Wrap"
                                       Foreground="{StaticResource FgSecondaryBrush}"/>
                            <Button HorizontalAlignment="Left" Padding="12,6" Classes="themed"
                                    Content="{Binding Step2OpenAdvancedForTokenLabel}"
                                    Command="{Binding OpenAdvancedForHuggingFaceCommand}"/>
                        </StackPanel>
                    </Border>
                    <TextBlock FontSize="11" TextWrapping="Wrap"
                               Foreground="{StaticResource SuccessBrush}"
                               Text="{Binding Step2HuggingFaceTokenOkHint}"
                               IsVisible="{Binding HasHuggingFaceTokenConfigured}"/>

                    <Border Padding="16,14" CornerRadius="8"
                            Background="{StaticResource BgSurfaceBrush}">
                        <StackPanel Spacing="10">
                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel>
                                    <TextBlock Text="{Binding Step2CardTitle}" FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource FgPrimaryBrush}"/>
                                    <TextBlock Text="{Binding Step2CardSubtitle}"
                                               FontSize="11"
                                               Foreground="{StaticResource FgTertiaryBrush}"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                                <Button Grid.Column="1" Content="{Binding Step2DownloadButton}" Classes="accent"
                                        Padding="16,8" VerticalAlignment="Center"
                                        Command="{Binding DownloadModelCommand}"
                                        IsVisible="{Binding !IsModelInstalled}"/>
                                <TextBlock Grid.Column="1" Text="{Binding Step2ReadyLabel}" FontSize="13"
                                           Foreground="{StaticResource SuccessBrush}"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           IsVisible="{Binding IsModelInstalled}"/>
                            </Grid>

                            <ProgressBar Classes="wizard" Minimum="0" Maximum="100"
                                         Value="{Binding DownloadProgress}"
                                         IsVisible="{Binding IsDownloading}"/>

                            <Grid ColumnDefinitions="*,Auto"
                                  IsVisible="{Binding DownloadStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                <TextBlock Text="{Binding DownloadStatus}" FontSize="11"
                                           TextWrapping="Wrap"
                                           Foreground="{StaticResource FgTertiaryBrush}"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                    <Button Content="{Binding CopyUrlButtonLabel}" Padding="8,3"
                                            FontSize="11" MinWidth="0" MinHeight="0"
                                            Classes="themed" VerticalAlignment="Top"
                                            Command="{Binding CopyUrlCommand}"
                                            IsVisible="{Binding HasError}"/>
                                    <Button Content="{Binding Step2OpenModelOnHuggingFaceLabel}" Padding="8,3"
                                            FontSize="11" MinWidth="0" MinHeight="0"
                                            Classes="themed" VerticalAlignment="Top"
                                            Command="{Binding OpenRequiredModelOnHuggingFaceCommand}"
                                            IsVisible="{Binding ShowOpenModelPageOnDownloadFailure}"/>
                                    <Button Content="{Binding Step2CancelButton}" Padding="8,3"
                                            FontSize="11" MinWidth="0" MinHeight="0"
                                            Classes="themed" VerticalAlignment="Top"
                                            Command="{Binding CancelDownloadCommand}"
                                            IsVisible="{Binding IsDownloading}"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </DockPanel>
    </Panel>
</Window>
