<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="LiveLingo.App.Views.MainWindow"
        Title="LiveLingo"
        Width="360" Height="240"
        CanResize="False"
        WindowStartupLocation="CenterScreen">

    <Window.Styles>
        <Style Selector="TextBlock.title">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        <Style Selector="TextBlock.hint">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#888"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <Style Selector="Border.badge">
            <Setter Property="Background" Value="#2228A745"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="10,6"/>
        </Style>
    </Window.Styles>

    <StackPanel Margin="24" Spacing="14" VerticalAlignment="Center">
        <TextBlock Classes="title" Text="LiveLingo"/>
        <TextBlock Classes="hint"
                   Text="Global hotkey registered. Press the shortcut while any app is focused to open the translation overlay."/>
        <Border Classes="badge">
            <TextBlock Name="HotkeyDisplay"
                       Text="⌨  Ctrl + Alt + T"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="#28A745"
                       HorizontalAlignment="Center"/>
        </Border>
        <TextBlock Classes="hint"
                   Text="Keep this window open (minimize is OK). The overlay pops up over the active window."
                   HorizontalAlignment="Center"/>
        <Button Content="⚙ Settings" HorizontalAlignment="Center"
                Name="SettingsButton" Padding="16,6"
                Click="OnSettingsClick"/>
    </StackPanel>
</Window>
