<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:LiveLingo.App.ViewModels"
        xmlns:ctrl="using:LiveLingo.App.Controls"
        x:Class="LiveLingo.App.Views.SettingsWindow"
        x:DataType="vm:SettingsViewModel"
        Title="LiveLingo Settings"
        Width="540" Height="520"
        CanResize="False"
        WindowStartupLocation="CenterScreen"
        TransparencyLevelHint="AcrylicBlur"
        Background="Transparent"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="-1">

    <Window.Styles>
        <Style Selector="TextBlock.section">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#98989D"/>
            <Setter Property="Margin" Value="0,14,0,6"/>
        </Style>
        <Style Selector="TextBlock.label">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#C7C7CC"/>
        </Style>
        <Style Selector="TextBlock.hint">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#8E8E93"/>
            <Setter Property="Margin" Value="0,3,0,0"/>
        </Style>
        <Style Selector="TextBox">
            <Setter Property="Background" Value="#0D0D0F"/>
            <Setter Property="Foreground" Value="#E5E5E7"/>
            <Setter Property="BorderBrush" Value="#2A2A2C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="CaretBrush" Value="#0A84FF"/>
        </Style>
        <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
            <Setter Property="BorderBrush" Value="#0A84FF"/>
        </Style>
        <Style Selector="ComboBox">
            <Setter Property="Background" Value="#0D0D0F"/>
            <Setter Property="Foreground" Value="#E5E5E7"/>
            <Setter Property="BorderBrush" Value="#2A2A2C"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
        <Style Selector="NumericUpDown">
            <Setter Property="Background" Value="#0D0D0F"/>
            <Setter Property="Foreground" Value="#E5E5E7"/>
            <Setter Property="BorderBrush" Value="#2A2A2C"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
        <Style Selector="Separator">
            <Setter Property="Margin" Value="0,10,0,0"/>
            <Setter Property="Background" Value="#1C1C1E"/>
        </Style>
        <Style Selector="Button">
            <Setter Property="Background" Value="#2A2A2C"/>
            <Setter Property="Foreground" Value="#E5E5E7"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
        <Style Selector="Button.accent">
            <Setter Property="Background" Value="#0A84FF"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
        </Style>
        <Style Selector="Button.danger">
            <Setter Property="Background" Value="#FF453A"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
        </Style>
        <Style Selector="Button.sm">
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="MinHeight" Value="0"/>
        </Style>
        <Style Selector="TabItem">
            <Setter Property="Foreground" Value="#98989D"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="Slider">
            <Setter Property="Foreground" Value="#0A84FF"/>
        </Style>
        <Style Selector="ProgressBar">
            <Setter Property="Foreground" Value="#0A84FF"/>
            <Setter Property="Background" Value="#1C1C1E"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="MinHeight" Value="4"/>
            <Setter Property="MaxHeight" Value="4"/>
        </Style>
    </Window.Styles>

    <Panel>
        <ExperimentalAcrylicBorder Name="AcrylicBg" IsHitTestVisible="False">
            <ExperimentalAcrylicBorder.Material>
                <ExperimentalAcrylicMaterial
                    BackgroundSource="Digger"
                    TintColor="#0D0D0F"
                    TintOpacity="0.92"
                    MaterialOpacity="0.92"/>
            </ExperimentalAcrylicBorder.Material>
        </ExperimentalAcrylicBorder>

        <Border IsHitTestVisible="False"
                BorderBrush="#10FFFFFF" BorderThickness="1"
                CornerRadius="8"/>

        <DockPanel Margin="24,36,24,20">
            <TextBlock DockPanel.Dock="Top" Name="TitleText" Text="Settings"
                       FontSize="18" FontWeight="SemiBold"
                       Foreground="#E5E5E7" Margin="0,0,0,14"/>

            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                        HorizontalAlignment="Right" Spacing="8" Margin="0,14,0,0">
                <Button Name="ResetBtn" Content="Reset Defaults" Command="{Binding ResetCommand}"
                        Padding="14,7"/>
                <Button Name="CancelBtn" Content="Cancel" Command="{Binding CancelCommand}"
                        Padding="14,7"/>
                <Button Name="SaveBtn" Content="Save" Command="{Binding SaveCommand}"
                        Padding="14,7" IsDefault="True" Classes="accent"/>
            </StackPanel>

            <TabControl>
                <!-- General -->
                <TabItem Name="TabGeneral" Header="General">
                    <ScrollViewer>
                        <StackPanel Spacing="2" Margin="0,4">
                            <TextBlock Classes="section" Text="Hotkeys"/>
                            <Grid ColumnDefinitions="130,*">
                                <TextBlock Classes="label" Text="Overlay Toggle:"/>
                                <ctrl:HotkeyRecorder Grid.Column="1"
                                    Hotkey="{Binding OverlayHotkey, Mode=TwoWay}"/>
                            </Grid>
                            <TextBlock Classes="hint" Text="Click the field, then press a key combo"/>
                            <Separator/>
                            <TextBlock Classes="section" Text="Overlay"/>
                            <Grid ColumnDefinitions="130,*" RowDefinitions="Auto,Auto" RowSpacing="10">
                                <TextBlock Classes="label" Text="Opacity:"/>
                                <Grid Grid.Column="1" ColumnDefinitions="*,36">
                                    <Slider Minimum="0.3" Maximum="1.0"
                                            Value="{Binding OverlayOpacity}"
                                            TickFrequency="0.05" IsSnapToTickEnabled="True"/>
                                    <TextBlock Grid.Column="1" VerticalAlignment="Center"
                                               HorizontalAlignment="Right" FontSize="11"
                                               Foreground="#98989D">
                                        <TextBlock.Text>
                                            <Binding Path="OverlayOpacity" StringFormat="{}{0:P0}"/>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </Grid>
                                <TextBlock Grid.Row="1" Classes="label" Text="Injection Mode:"/>
                                <ComboBox Grid.Row="1" Grid.Column="1" MinWidth="160"
                                          ItemsSource="{Binding InjectionModes}"
                                          SelectedItem="{Binding DefaultInjectionMode}"/>
                            </Grid>
                            <Separator/>
                            <TextBlock Classes="section" Text="Language"/>
                            <Grid ColumnDefinitions="130,*">
                                <TextBlock Classes="label" Text="UI Language:"/>
                                <ComboBox Grid.Column="1" MinWidth="160"
                                          ItemsSource="{Binding UILanguages}"
                                          SelectedItem="{Binding SelectedUILanguage}"/>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- Translation -->
                <TabItem Name="TabTranslation" Header="Translation">
                    <ScrollViewer>
                        <StackPanel Spacing="2" Margin="0,4">
                            <TextBlock Classes="section" Text="Default Language Pair"/>
                            <Grid ColumnDefinitions="130,*" RowDefinitions="Auto,Auto" RowSpacing="10">
                                <TextBlock Classes="label" Text="Source Language:"/>
                                <ComboBox Grid.Column="1" MinWidth="200"
                                          ItemsSource="{Binding AvailableLanguages}"
                                          SelectedItem="{Binding SelectedSourceLanguage}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding DisplayName}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <TextBlock Grid.Row="1" Classes="label" Text="Target Language:"/>
                                <ComboBox Grid.Row="1" Grid.Column="1" MinWidth="200"
                                          ItemsSource="{Binding AvailableLanguages}"
                                          SelectedItem="{Binding SelectedTargetLanguage}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding DisplayName}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- Models -->
                <TabItem Name="TabModels" Header="Models">
                    <ScrollViewer>
                        <ItemsControl ItemsSource="{Binding Models}" Margin="0,4">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:ModelItemViewModel">
                                    <Border Margin="0,0,0,6" Padding="12,10"
                                            CornerRadius="8" Background="#1C1C1E">
                                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto">
                                            <!-- Row 0: Name + action -->
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <Border Background="#200A84FF" CornerRadius="4" Padding="6,2">
                                                    <TextBlock Text="{Binding TypeLabel}"
                                                               FontSize="10" Foreground="#0A84FF"/>
                                                </Border>
                                                <TextBlock Text="{Binding DisplayName}"
                                                           Foreground="#FFFFFF" FontSize="13"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                                                <!-- Download button -->
                                                <Button Classes="accent sm"
                                                        Content="Download"
                                                        Command="{Binding DownloadCommand}"
                                                        IsVisible="{Binding !IsInstalled}"/>
                                                <!-- Cancel button -->
                                                <Button Classes="sm"
                                                        Content="Cancel"
                                                        Command="{Binding CancelDownloadCommand}"
                                                        IsVisible="{Binding IsDownloading}"/>
                                                <!-- Installed badge -->
                                                <TextBlock Text="✓ Installed" FontSize="11"
                                                           Foreground="#30D158"
                                                           VerticalAlignment="Center"
                                                           IsVisible="{Binding IsInstalled}"/>
                                                <!-- Delete button -->
                                                <Button Classes="danger sm"
                                                        Content="Delete"
                                                        Command="{Binding DeleteCommand}"
                                                        IsVisible="{Binding IsInstalled}"/>
                                            </StackPanel>

                                            <!-- Row 1: Size + status -->
                                            <StackPanel Grid.Row="1" Grid.ColumnSpan="2"
                                                        Orientation="Horizontal" Spacing="12"
                                                        Margin="0,4,0,0">
                                                <TextBlock Text="{Binding SizeText}"
                                                           FontSize="11" Foreground="#98989D"/>
                                                <TextBlock Text="{Binding ErrorMessage}"
                                                           FontSize="11" Foreground="#FF453A"
                                                           IsVisible="{Binding ErrorMessage,
                                                               Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                            </StackPanel>

                                            <!-- Row 2: Progress bar -->
                                            <ProgressBar Grid.Row="2" Grid.ColumnSpan="2"
                                                         Margin="0,6,0,0"
                                                         Minimum="0" Maximum="100"
                                                         Value="{Binding DownloadProgress}"
                                                         IsVisible="{Binding IsDownloading}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </TabItem>

                <!-- Advanced -->
                <TabItem Name="TabAdvanced" Header="Advanced">
                    <ScrollViewer>
                        <StackPanel Spacing="2" Margin="0,4">
                            <TextBlock Classes="section" Text="Model Storage"/>
                            <Grid ColumnDefinitions="130,*,Auto">
                                <TextBlock Classes="label" Text="Storage Path:"/>
                                <TextBox Grid.Column="1" Text="{Binding ModelStoragePath}"
                                         Watermark="Default (AppData)"/>
                                <Button Grid.Column="2" Content="Browse…"
                                        Click="BrowseModelPath_Click"
                                        Margin="6,0,0,0" Padding="10,6"
                                        Classes="sm"/>
                            </Grid>
                            <TextBlock FontSize="11" Foreground="#FF453A"
                                       Text="{Binding MigrationError}"
                                       IsVisible="{Binding MigrationError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                       Margin="0,3,0,0"/>
                            <Separator/>
                            <TextBlock Classes="section" Text="Performance"/>
                            <Grid ColumnDefinitions="130,*">
                                <TextBlock Classes="label" Text="Inference Threads:"/>
                                <NumericUpDown Grid.Column="1" Minimum="0" Maximum="32"
                                               Value="{Binding InferenceThreads}"
                                               MinWidth="100" HorizontalAlignment="Left"/>
                            </Grid>
                            <TextBlock Classes="hint" Text="0 = auto-detect (recommended)"/>
                            <Separator/>
                            <TextBlock Classes="section" Text="Logging"/>
                            <Grid ColumnDefinitions="130,*">
                                <TextBlock Classes="label" Text="Log Level:"/>
                                <ComboBox Grid.Column="1" MinWidth="160"
                                          ItemsSource="{Binding LogLevels}"
                                          SelectedItem="{Binding LogLevel}"/>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- AI -->
                <TabItem Name="TabAI" Header="AI">
                    <ScrollViewer>
                        <StackPanel Spacing="2" Margin="0,4">
                            <TextBlock Classes="section" Text="Post-Processing"/>
                            <Grid ColumnDefinitions="130,*">
                                <TextBlock Classes="label" Text="Default Mode:"/>
                                <ComboBox Grid.Column="1" MinWidth="160"
                                          ItemsSource="{Binding PostProcessModes}"
                                          SelectedItem="{Binding DefaultPostProcessMode}"/>
                            </Grid>
                            <TextBlock Classes="hint"
                                       Text="Summarize · Optimize · Colloquialize"/>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </DockPanel>
    </Panel>
</Window>
